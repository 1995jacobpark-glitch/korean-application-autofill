{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HWP Resume Autofill Profile",
  "type": "object",
  "required": ["person", "work", "education", "licenses", "careers"],
  "properties": {
    "person": {
      "type": "object",
      "properties": {
        "nameKo": { "type": "string" },
        "nameEn": { "type": "string" },
        "birthDate": { "type": "string" },
        "phoneHome": { "type": "string" },
        "mobile": { "type": "string" },
        "email": { "type": "string" },
        "addressHome": { "type": "string" }
      }
    },
    "work": {
      "type": "object",
      "properties": {
        "company": { "type": "string" },
        "position": { "type": "string" },
        "rank": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "fax": { "type": "string" }
      }
    },
    "education": { "type": "array" },
    "licenses": { "type": "array" },
    "careers": { "type": "array" },
    "committees": { "type": "array" },
    "awards": { "type": "array" },
    "projects": { "type": "array" }
  }
}
